{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DKCTF decoded Blender actions",
  "type": "object",
  "required": [
    "format",
    "actions"
  ],
  "properties": {
    "format": {
      "const": "DKCTF_DECODED_ACTIONS_V1"
    },
    "fps": {
      "type": "integer",
      "minimum": 1
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "channels"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "channels": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "bone",
                "frames"
              ],
              "properties": {
                "bone": {
                  "type": "string",
                  "minLength": 1
                },
                "frames": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": [
                      "frame",
                      "local_matrix_row_major"
                    ],
                    "properties": {
                      "frame": {
                        "type": "integer"
                      },
                      "local_matrix_row_major": {
                        "type": "array",
                        "minItems": 16,
                        "maxItems": 16,
                        "items": {
                          "type": "number"
                        }
                      }
                    },
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}